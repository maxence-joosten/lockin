#!/usr/bin/env bash

# ─────────────────────────────────────────────────────────────────────────────
#  lockin — terminal focus session manager for Linux
#  blocks distracting sites via /etc/hosts, kills distracting apps,
#  shows a random quote + ascii art countdown timer
# ─────────────────────────────────────────────────────────────────────────────

# ── Config — edit these to match your habits ─────────────────────────────────

BLOCK_MARKER="# lockin-block"

BLOCKED_SITES=(
  "twitter.com" "www.twitter.com"
  "x.com" "www.x.com"
  "reddit.com" "www.reddit.com" "old.reddit.com"
  "youtube.com" "www.youtube.com" "m.youtube.com"
  "instagram.com" "www.instagram.com"
  "tiktok.com" "www.tiktok.com"
  "facebook.com" "www.facebook.com"
  "twitch.tv" "www.twitch.tv"
  "netflix.com" "www.netflix.com"
  "linkedin.com" "www.linkedin.com"
  "anilist.co" "www.anilist.co"
)

# Process names to kill (matched with pkill -f)
BLOCKED_APPS=(
  "vesktop"
  "steam"
  "stremio"
)

# ── Colour helpers ────────────────────────────────────────────────────────────

bold() { printf '\033[1m%s\033[0m' "$*"; }
dim() { printf '\033[2m%s\033[0m' "$*"; }
green() { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }
cyan() { printf '\033[36m%s\033[0m' "$*"; }
red() { printf '\033[31m%s\033[0m' "$*"; }

# ── DNS flush ─────────────────────────────────────────────────────────────────

flush_dns() {
  if command -v resolvectl &>/dev/null; then
    sudo resolvectl flush-caches 2>/dev/null
  elif command -v systemd-resolve &>/dev/null; then
    sudo systemd-resolve --flush-caches 2>/dev/null
  fi
}

# ── Website blocking via /etc/hosts ──────────────────────────────────────────

block_sites() {
  if grep -q "$BLOCK_MARKER" /etc/hosts 2>/dev/null; then
    echo "  $(yellow '⚠') sites already blocked"
    return
  fi

  printf "  $(cyan '→') blocking %d domains..." "${#BLOCKED_SITES[@]}"
  {
    echo ""
    echo "$BLOCK_MARKER"
    for site in "${BLOCKED_SITES[@]}"; do
      echo "127.0.0.1  $site"
    done
    echo "$BLOCK_MARKER end"
  } | sudo tee -a /etc/hosts >/dev/null

  flush_dns
  echo " $(green '✓')"
}

unblock_sites() {
  printf "  $(cyan '→') unblocking sites..."
  sudo sed -i "/$BLOCK_MARKER/,/$BLOCK_MARKER end/d" /etc/hosts
  flush_dns
  echo " $(green '✓')"
}

# ── App killing ───────────────────────────────────────────────────────────────

kill_apps() {
  for app in "${BLOCKED_APPS[@]}"; do
    PIDS=$(pgrep -f "$app")
    [[ -z "$PIDS" ]] && continue

    echo "  $(yellow '→') closing $app..."

    pkill -15 -f "$app"
    sleep 2

    if pgrep -f "$app" &>/dev/null; then
      echo "  $(red '⚠') force killing $app"
      pkill -9 -f "$app"
    else
      echo "  $(green '✓') closed $app"
    fi
  done
}

# ── Random quote ──────────────────────────────────────────────────────────────

_random_quote() {
  if command -v fortune &>/dev/null; then
    fortune -s |
      tr -d '\r' |
      tr '\n' ' ' |
      tr '\t' ' ' |
      sed -E 's/[[:space:]]+/ /g' |
      sed 's/--/ - /g' |
      sed 's/"/'\''/g' |
      sed 's/[^[:print:]]//g' |
      sed 's/^ *//; s/ *$//' |
      cut -c1-180
  else
    local quotes=(
      "focus is a matter of deciding what things you're not going to do."
      "the scarce resource isn't ideas, it's the ability to execute."
      "one hour of focused work beats eight hours of fragmented effort."
      "deep work is the superpower of the 21st century."
      "do the hard thing first. everything else is just noise."
      "clarity about what matters most is the precondition for great work."
      "protect your attention like it's your most valuable asset — it is."
      "what you do not start today cannot be finished tomorrow."
      "small disciplines repeated daily lead to great achievements."
      "the successful warrior is the average person with laser-like focus."
    )
    echo "${quotes[$RANDOM % ${#quotes[@]}]}"
  fi
}

# ── Session runner ───────────────────────────────────────────────────────────

run_session() {
  QUOTE=$(_random_quote)
  START_TIME=$(date +%s)

  echo ""
  echo "  $(bold "starting ${DURATION}-minute session")"
  echo ""

  if command -v arttime &>/dev/null; then
    arttime --nolearn --random \
      -g "${DURATION}m" \
      -t "❝ $QUOTE ❞"
  else
    echo "  $(yellow '⚠') arttime not found — using fallback timer"
    sleep "${DURATION}m"
  fi

  END_TIME=$(date +%s)
  ELAPSED=$(((END_TIME - START_TIME) / 60))
}

# ── Finish session ────────────────────────────────────────────────────────────

_finish() {
  echo ""

  [[ "$SITES_BLOCKED" == "1" ]] && unblock_sites

  echo ""
  echo "  $(bold "session ended") — $(date '+%H:%M')"

  if ((ELAPSED >= DURATION)); then
    echo "  $(green "✓ completed") — you focused for $(bold "${ELAPSED}") minutes."
  else
    echo "  $(yellow "⚠ quit early") — you focused for $(bold "${ELAPSED}") minutes."
  fi

  echo ""
}

# ── Main ──────────────────────────────────────────────────────────────────────

main() {
  clear
  echo ""
  echo "  $(bold "lockin")"
  echo "  $(dim "────────────────────────")"
  echo ""

  printf "  $(bold "how many minutes?") "
  read -r DURATION
  if ! [[ "$DURATION" =~ ^[0-9]+$ ]] || ((DURATION == 0)); then
    echo "  $(red 'error:') enter a positive whole number." >&2
    exit 1
  fi

  printf "  $(bold "block distracting websites?") (y/n) "
  read -r BLOCK_WEB

  printf "  $(bold "close distracting apps?") (y/n) "
  read -r BLOCK_APPS

  echo ""
  echo "  $(dim "────────────────────────")"

  SITES_BLOCKED=0

  if [[ "$BLOCK_WEB" =~ ^[Yy] ]]; then
    block_sites
    SITES_BLOCKED=1
  fi

  [[ "$BLOCK_APPS" =~ ^[Yy] ]] && kill_apps

  run_session
  _finish
}

main "$@"
